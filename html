<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'League Spartan',sans-serif;
}

body{
background:linear-gradient(135deg,#0a3d2b,#1e1e1e,#8ea604);
color:white;
overflow-x:hidden;
}

/* NAVBAR */

nav{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px 60px;
background:rgba(0,0,0,0.6);
backdrop-filter:blur(8px);
}

.logo{
font-size:30px;
font-weight:700;
background:linear-gradient(45deg,#e7ff0f,#18ff8b);
-webkit-background-clip:text;
color:transparent;
}

nav ul{
display:flex;
list-style:none;
gap:35px;
}

nav ul li{
cursor:pointer;
transition:0.3s;
}

nav ul li:hover{
color:#d4ff00;
transform:translateY(-3px);
}

/* HERO */

.hero{
height:90vh;
display:flex;
align-items:center;
justify-content:center;
text-align:center;
background:url("https://images.unsplash.com/photo-1517649763962-0c623066013b") center/cover;
position:relative;
}

.hero::after{
content:'';
position:absolute;
inset:0;
background:rgba(0,0,0,0.65);
}

.hero-content{
position:relative;
z-index:1;
animation:fadeIn 2s ease;
}

.hero h1{
font-size:80px;
background:linear-gradient(90deg,#d9ff00,#0aff84);
-webkit-background-clip:text;
color:transparent;
}

.hero p{
font-size:22px;
margin-top:10px;
}

/* PRODUCTS */

.section{
padding:80px 10%;
}

.section-title{
font-size:45px;
margin-bottom:50px;
text-align:center;
background:linear-gradient(90deg,#e7ff0f,#15ff8c);
-webkit-background-clip:text;
color:transparent;
}

.products{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:40px;
}

/* PARALLELOGRAM CARD */

.card{
background:#111;
padding:20px;
transform:skewY(-3deg);
border-radius:15px;
box-shadow:0 10px 40px rgba(0,0,0,0.7);
transition:0.8s;
}

.card:hover{
transform:scale(1.05) skewY(-3deg);
}

.card img{
width:100%;
border-radius:12px;
}

.card h3{
margin-top:10px;
}

/* ATHLETES */

.athletes{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:40px;
}

.athlete{
position:relative;
overflow:hidden;
border-radius:20px;
}

.athlete img{
width:100%;
transition:0.5s;
}

.athlete:hover img{
transform:scale(1.2);
}

.athlete-title{
position:absolute;
bottom:20px;
left:20px;
font-size:30px;
background:rgba(0,0,0,0.7);
padding:10px;
}

/* SHOES */

.shoes-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:30px;
}

/* FOOTER */

footer{
background:#000;
padding:60px;
text-align:center;
}

footer h2{
margin-bottom:20px;
}

.contact{
margin-top:20px;
line-height:2;
}

/* ANIMATIONS */

@keyframes fadeIn{
from{opacity:0;transform:translateY(50px)}
to{opacity:1;transform:translateY(0)}
}

</style>
</head>

